# Environment variables file (.env)
# Usage: source this file before running Packer to set common variables.
#   set -a     # automatically export all variables
#   source .env
#   set +a     # disable automatic exporting
#
# Variables can also be overridden via -var or -var-file command-line flags.

# Infrastructure parameters
PACKER_ISO_DIR="/home/iso"          # Base directory where ISO files are stored
PACKER_ARTIFACTS_DIR="/home/artifacts"  # Directory where build artifacts will be placed

# SSH credentials for connecting to the VM during provisioning
# For security, these should be set via environment or masked variables,
# not hard‑coded in version control.
PACKER_SSH_LOGIN="login"             # SSH username
PACKER_SSH_PASSWORD="password"       # SSH password
